{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@meet-ai/cli/*": ["./src/*"]
    }
  },
  "include": ["src", "test"]
}
