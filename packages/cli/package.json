{
  "name": "@meet-ai/cli",
  "version": "0.5.5",
  "description": "CLI for meet-ai chat rooms — create rooms, send messages, and stream via WebSocket",
  "keywords": [
    "chat",
    "cli",
    "meet-ai",
    "real-time",
    "websocket"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoftWare-A-G/meet-ai.git",
    "directory": "packages/cli"
  },
  "bin": {
    "meet-ai": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "generate:app-server-types": "codex app-server generate-ts --experimental --out src/generated/codex-app-server",
    "build": "bun build src/index.ts --production --outdir dist --target node --format esm",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "citty": "0.2.1",
    "evlog": "2.4.1",
    "hono": "4.12.5",
    "ink": "6.8.0",
    "picocolors": "1.1.1",
    "react": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
