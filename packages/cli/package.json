{
  "name": "@meet-ai/cli",
  "version": "2.3.2",
  "description": "CLI for meet-ai chat rooms — create rooms, send messages, and stream via WebSocket",
  "keywords": [
    "chat",
    "cli",
    "meet-ai",
    "real-time",
    "websocket"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoftWare-A-G/meet-ai.git",
    "directory": "packages/cli"
  },
  "bin": {
    "meet-ai": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "generate:app-server-types": "codex app-server generate-ts --experimental --out src/generated/codex-app-server",
    "build": "bun build src/index.ts --production --outdir dist --target node --format esm",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inkjs/ui": "2.0.0",
    "@mariozechner/pi-coding-agent": "0.62.0",
    "@opencode-ai/sdk": "1.3.0",
    "@sinclair/typebox": "0.34.48",
    "@tldraw/tlschema": "4.5.3",
    "citty": "0.2.1",
    "evlog": "2.9.0",
    "hono": "4.12.9",
    "ink": "6.8.0",
    "ink-link": "5.0.0",
    "picocolors": "1.1.1",
    "react": "19.2.4",
    "tldraw": "4.5.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
