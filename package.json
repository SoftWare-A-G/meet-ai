{
  "name": "meet-ai",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun --filter '*' test",
    "lint": "oxlint -f json",
    "lint-changed": "oxlint $(git diff --name-only) -f json",
    "lint-changed:fix": "oxlint $(git diff --name-only) --fix -f json",
    "lint-staged": "oxlint $(git diff --cached --name-only) -f json",
    "lint-staged:fix": "oxlint $(git diff --cached --name-only) --fix -f json",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "typescript": "catalog:"
  },
  "catalog": {
    "@base-ui/react": "1.3.0",
    "@cloudflare/workers-types": "4.20260317.1",
    "@elevenlabs/elevenlabs-js": "2.40.0",
    "@hono/zod-validator": "0.7.6",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "5.95.2",
    "@types/bun": "1.3.11",
    "@types/node": "25.0.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "hono": "4.12.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  }
}
