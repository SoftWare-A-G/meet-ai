{
  "name": "meet-ai",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun --filter '*' test",
    "lint": "oxlint -f json",
    "lint-changed": "oxlint $(git diff --name-only) -f json",
    "lint-changed:fix": "oxlint $(git diff --name-only) --fix -f json",
    "lint-staged": "oxlint $(git diff --cached --name-only) -f json",
    "lint-staged:fix": "oxlint $(git diff --cached --name-only) --fix -f json",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "oxfmt": "0.26.0",
    "oxlint": "1.41.0",
    "typescript": "catalog:"
  },
  "catalog": {
    "@base-ui/react": "1.2.0",
    "@cloudflare/workers-types": "4.20260307.1",
    "@elevenlabs/elevenlabs-js": "2.38.1",
    "@hono/zod-validator": "0.7.6",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/bun": "1.3.10",
    "@types/node": "25.0.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "hono": "4.12.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "3.2.4",
    "zod": "4.3.6"
  }
}
